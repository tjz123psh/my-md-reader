<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="io.github.pang.mdreader" path="/io/github/pang/mdreader/">
    <key name="window-width" type="i">
      <default>1200</default>
      <summary>窗口宽度</summary>
    </key>
    <key name="window-height" type="i">
      <default>800</default>
      <summary>窗口高度</summary>
    </key>
    <key name="window-maximized" type="b">
      <default>false</default>
      <summary>窗口是否最大化</summary>
    </key>
    <key name="last-workspace" type="s">
      <default>''</default>
      <summary>上次打开的工作区路径</summary>
    </key>
    <key name="last-document" type="s">
      <default>''</default>
      <summary>上次打开的文档相对工作区的路径</summary>
    </key>
    <key name="document-zoom" type="i">
      <range min="75" max="200" />
      <default>100</default>
      <summary>文档缩放百分比</summary>
    </key>
    <key name="color-scheme" type="s">
      <choices>
        <choice value="warm-paper" />
        <choice value="mist-blue" />
        <choice value="sage-leaf" />
        <choice value="midnight-ink" />
        <choice value="plum-night" />
        <!-- Accepted for migration from releases before the five-theme picker. -->
        <choice value="system" />
        <choice value="warm-light" />
        <choice value="warm-dark" />
      </choices>
      <default>'warm-paper'</default>
      <summary>应用与阅读器的统一主题</summary>
    </key>
    <key name="library-sidebar-width" type="i">
      <range min="180" max="720" />
      <default>260</default>
      <summary>目录侧栏宽度</summary>
    </key>
    <key name="ai-sidebar-width" type="i">
      <range min="180" max="720" />
      <default>360</default>
      <summary>AI 助手侧栏宽度</summary>
    </key>
    <key name="opencode-model" type="s">
      <default>''</default>
      <summary>上次选择的 OpenCode 模型标识符</summary>
    </key>
  </schema>
</schemalist>
